---
import Layout from '../../layouts/Layout.astro';
import { BOOKING_URL, TOOLS_INDEX_URL, TOOLS_SITE, type ToolMeta } from '../../data/tools';
import { relatedTools } from '../../data/tools';

interface Props {
  tool: ToolMeta;
  description?: string;
}

const { tool, description } = Astro.props as Props;
const desc = description ?? tool.description;
const related = relatedTools(tool.slug);

const medicalWebPage = {
  '@type': 'MedicalWebPage',
  '@id': `${tool.url}#webpage`,
  url: tool.url,
  name: tool.pageHeading,
  description: desc,
  inLanguage: 'zh-Hant',
  about: { '@type': 'MedicalEntity', name: tool.keyword },
  author: { '@id': `${TOOLS_SITE}/#person` },
  reviewedBy: { '@id': `${TOOLS_SITE}/#person` },
  isAccessibleForFree: true,
};

const softwareApp = {
  '@type': 'SoftwareApplication',
  '@id': `${tool.url}#calculator`,
  name: tool.pageHeading,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'TWD' },
  creator: { '@id': `${TOOLS_SITE}/#person` },
  url: tool.url,
};

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${TOOLS_SITE}/` },
    { '@type': 'ListItem', position: 2, name: '醫療計算機', item: TOOLS_INDEX_URL },
    { '@type': 'ListItem', position: 3, name: tool.pageHeading, item: tool.url },
  ],
};
---

<Layout title={tool.title} description={desc} jsonLd={[medicalWebPage, softwareApp, breadcrumb]}>
  <main class="max-w-4xl mx-auto px-6 md:px-10 py-12 print:py-4 print:px-4 print:max-w-none">
    <nav class="text-xs text-slate-500 mb-6 print:hidden" aria-label="breadcrumb">
      <a href="/" class="hover:text-teal-700">首頁</a>
      <span class="mx-2">／</span>
      <a href="/tools/" class="hover:text-teal-700">醫療計算機</a>
      <span class="mx-2">／</span>
      <span>{tool.pageHeading}</span>
    </nav>

    <header class="mb-8 print:mb-4">
      <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-3">
        Medical Calculator · 陳昱彰醫師 整理
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-blue-950 mb-3 font-headline">
        <span class="mr-2">{tool.emoji}</span>{tool.pageHeading}
      </h1>
      <p class="text-slate-600 chinese-line-height">{desc}</p>
    </header>

    <slot />

    <section class="mt-12 print:hidden">
      <div class="rounded-2xl bg-gradient-to-br from-primary to-primary-container text-on-primary p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-bold mb-2 font-headline">需要醫師親自評估？</h2>
        <p class="text-on-primary-container chinese-line-height mb-4">
          計算機只能呈現數字，藥物適應症、共病管理與行為改變需要在診間個別評估。歡迎線上預約義大醫院家醫科陳昱彰醫師門診。
        </p>
        <a
          href={BOOKING_URL}
          target="_blank"
          rel="noopener"
          class="inline-block bg-white text-primary px-6 py-3 rounded-full font-bold text-sm tracking-tight hover:opacity-90 transition-opacity no-underline"
        >
          義大醫院線上預約掛號 →
        </a>
      </div>
    </section>

    {related.length > 0 && (
      <section class="mt-12 border-t border-outline-variant pt-8 print:hidden">
        <h2 class="text-lg font-bold text-blue-950 mb-4">相關計算機</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {related.map((r) => (
            <a
              href={r.url.replace(TOOLS_SITE, '')}
              class="block p-4 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors no-underline"
            >
              <span class="text-2xl">{r.emoji}</span>
              <div class="text-sm font-bold text-blue-950 mt-2">{r.shortLabel}</div>
              <div class="text-xs text-slate-500 mt-1">{r.audience}</div>
            </a>
          ))}
          <a
            href="/tools/dashboard/"
            class="block p-4 rounded-xl bg-secondary-container hover:opacity-90 transition-opacity no-underline"
          >
            <span class="text-2xl">🩺</span>
            <div class="text-sm font-bold text-on-secondary-container mt-2">減重綜合儀表板</div>
            <div class="text-xs text-on-secondary-container/80 mt-1">一頁全部算完，可列印</div>
          </a>
        </div>
      </section>
    )}

    <footer class="mt-12 text-xs text-slate-500 chinese-line-height border-t border-outline-variant pt-6 print:mt-6 print:pt-3 print:text-[10px]">
      <p class="font-bold mb-2 text-slate-700">⚠️ 醫療免責聲明</p>
      <p>
        本計算機公式採用衛福部國民健康署及國際公認之臨床標準，僅供健康評估參考，
        <strong>不能取代醫師診斷或治療建議</strong>。如需個人化評估與治療計畫，請至門診由醫師親自評估。
      </p>
      <p class="mt-2">
        本網站不儲存任何個人資料，所有輸入僅儲存在您的瀏覽器（localStorage），可在頁面下方按「清除資料」隨時刪除。
      </p>
    </footer>
  </main>
</Layout>

<style is:global>
  @media print {
    header.sticky, footer { display: none !important; }
    body { background: white !important; }
    .print\\:hidden { display: none !important; }
  }
</style>
