---
import { ACTIVITY_LEVELS, COMORBIDITY_LABELS } from '../../scripts/tools/calculators';

interface Props {
  fields: readonly string[];
  title?: string;
  showClear?: boolean;
}

const {
  fields,
  title = '請輸入您的資料',
  showClear = true,
} = Astro.props as Props;

const has = (f: string) => fields.includes(f);
const comorbidityKeys = Object.keys(COMORBIDITY_LABELS) as (keyof typeof COMORBIDITY_LABELS)[];
---

<form
  data-metrics-form
  class="rounded-2xl bg-surface-container p-6 md:p-8 mb-8 print:mb-4 print:p-4 print:bg-white print:border print:border-slate-300"
  novalidate
>
  <div class="flex items-baseline justify-between mb-5">
    <h2 class="text-lg font-bold text-blue-950 font-headline">{title}</h2>
    {showClear && (
      <button
        type="button"
        data-clear-metrics
        class="text-xs text-slate-500 hover:text-rose-700 underline print:hidden"
      >
        清除資料
      </button>
    )}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {has('sex') && (
      <fieldset class="md:col-span-2">
        <legend class="text-sm font-bold text-slate-700 mb-2">性別</legend>
        <div class="flex gap-3">
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="sex" value="male" class="peer sr-only" data-field="sex" />
            <div class="text-center py-3 px-4 rounded-xl border border-outline-variant bg-white peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary transition-colors">
              男性
            </div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="sex" value="female" class="peer sr-only" data-field="sex" />
            <div class="text-center py-3 px-4 rounded-xl border border-outline-variant bg-white peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary transition-colors">
              女性
            </div>
          </label>
        </div>
      </fieldset>
    )}

    {has('age') && (
      <label class="block">
        <span class="block text-sm font-bold text-slate-700 mb-1">年齡（歲）</span>
        <input
          type="number"
          inputmode="numeric"
          min="1"
          max="120"
          step="1"
          placeholder="例：45"
          data-field="age"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
        />
      </label>
    )}

    {has('heightCm') && (
      <label class="block">
        <span class="block text-sm font-bold text-slate-700 mb-1">身高（cm）</span>
        <input
          type="number"
          inputmode="decimal"
          min="50"
          max="250"
          step="0.1"
          placeholder="例：170"
          data-field="heightCm"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
        />
      </label>
    )}

    {has('weightKg') && (
      <label class="block">
        <span class="block text-sm font-bold text-slate-700 mb-1">體重（kg）</span>
        <input
          type="number"
          inputmode="decimal"
          min="20"
          max="300"
          step="0.1"
          placeholder="例：72.5"
          data-field="weightKg"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
        />
      </label>
    )}

    {has('waistCm') && (
      <label class="block">
        <span class="block text-sm font-bold text-slate-700 mb-1">腰圍（cm）</span>
        <input
          type="number"
          inputmode="decimal"
          min="40"
          max="200"
          step="0.1"
          placeholder="例：85"
          data-field="waistCm"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
        />
      </label>
    )}

    {has('hipCm') && (
      <label class="block">
        <span class="block text-sm font-bold text-slate-700 mb-1">
          臀圍（cm）<span class="font-normal text-slate-500">・選填，計算腰臀比</span>
        </span>
        <input
          type="number"
          inputmode="decimal"
          min="40"
          max="200"
          step="0.1"
          placeholder="例：95"
          data-field="hipCm"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
        />
      </label>
    )}

    {has('activityLevel') && (
      <label class="block md:col-span-2">
        <span class="block text-sm font-bold text-slate-700 mb-1">每週活動量</span>
        <select
          data-field="activityLevel"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
        >
          <option value="">請選擇</option>
          {ACTIVITY_LEVELS.map((opt) => (
            <option value={opt.value}>{opt.label}（{opt.detail}）</option>
          ))}
        </select>
      </label>
    )}

    {has('weightHistory') && (
      <>
        <label class="block">
          <span class="block text-sm font-bold text-slate-700 mb-1">起始體重（kg）</span>
          <input
            type="number"
            inputmode="decimal"
            min="20"
            max="300"
            step="0.1"
            placeholder="例：85"
            data-field="weightHistory.startWeightKg"
            class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
          />
        </label>
        <label class="block">
          <span class="block text-sm font-bold text-slate-700 mb-1">目標體重（kg）</span>
          <input
            type="number"
            inputmode="decimal"
            min="20"
            max="300"
            step="0.1"
            placeholder="例：70"
            data-field="weightHistory.targetWeightKg"
            class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
          />
        </label>
      </>
    )}
  </div>

  {has('comorbidities') && (
    <fieldset class="mt-5">
      <legend class="text-sm font-bold text-slate-700 mb-2">您是否有以下共病？（可多選）</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {comorbidityKeys.map((key) => (
          <label class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-outline-variant bg-white cursor-pointer hover:border-primary transition-colors">
            <input type="checkbox" data-field={`comorbidities.${key}`} class="accent-primary" />
            <span class="text-sm text-slate-700">{COMORBIDITY_LABELS[key]}</span>
          </label>
        ))}
      </div>
    </fieldset>
  )}
</form>

<script>
  import {
    loadMetrics,
    saveMetrics,
    clearMetrics,
    parseNumberInput,
    onMetricsChange,
    type PatientMetrics,
  } from '../../scripts/tools/metrics-store';
  import type { Comorbidities, ActivityLevel, Sex } from '../../scripts/tools/calculators';

  type AnyInput = HTMLInputElement | HTMLSelectElement;

  function hydrateForm(form: HTMLFormElement, m: PatientMetrics) {
    const inputs = form.querySelectorAll('[data-field]') as NodeListOf<AnyInput>;
    inputs.forEach((el) => {
      const field = el.dataset.field;
      if (!field) return;

      if (field === 'sex' && el instanceof HTMLInputElement) {
        el.checked = m.sex === el.value;
        return;
      }
      if (field.startsWith('comorbidities.') && el instanceof HTMLInputElement) {
        const key = field.split('.')[1] as keyof Comorbidities;
        el.checked = m.comorbidities[key] ?? false;
        return;
      }
      if (field === 'weightHistory.startWeightKg' && el instanceof HTMLInputElement) {
        el.value = m.weightHistory.startWeightKg != null ? String(m.weightHistory.startWeightKg) : '';
        return;
      }
      if (field === 'weightHistory.targetWeightKg' && el instanceof HTMLInputElement) {
        el.value = m.weightHistory.targetWeightKg != null ? String(m.weightHistory.targetWeightKg) : '';
        return;
      }
      if (field === 'activityLevel' && el instanceof HTMLSelectElement) {
        el.value = m.activityLevel != null ? String(m.activityLevel) : '';
        return;
      }
      // 一般數值欄位
      const v = (m as unknown as Record<string, number | null>)[field];
      if (el instanceof HTMLInputElement) {
        el.value = v != null ? String(v) : '';
      }
    });
  }

  function handleInput(form: HTMLFormElement, el: AnyInput) {
    const field = el.dataset.field;
    if (!field) return;

    if (field === 'sex' && el instanceof HTMLInputElement && el.checked) {
      saveMetrics({ sex: el.value as Sex });
      return;
    }
    if (field.startsWith('comorbidities.') && el instanceof HTMLInputElement) {
      const key = field.split('.')[1] as keyof Comorbidities;
      saveMetrics({ comorbidities: { [key]: el.checked } as Partial<Comorbidities> });
      return;
    }
    if (field === 'weightHistory.startWeightKg' && el instanceof HTMLInputElement) {
      saveMetrics({ weightHistory: { startWeightKg: parseNumberInput(el.value) } });
      return;
    }
    if (field === 'weightHistory.targetWeightKg' && el instanceof HTMLInputElement) {
      saveMetrics({ weightHistory: { targetWeightKg: parseNumberInput(el.value) } });
      return;
    }
    if (field === 'activityLevel' && el instanceof HTMLSelectElement) {
      const v = parseNumberInput(el.value);
      saveMetrics({ activityLevel: v as ActivityLevel | null });
      return;
    }
    if (el instanceof HTMLInputElement) {
      const v = parseNumberInput(el.value);
      saveMetrics({ [field]: v } as Record<string, number | null>);
    }
  }

  const forms = document.querySelectorAll('[data-metrics-form]') as NodeListOf<HTMLFormElement>;
  forms.forEach((form) => {
    hydrateForm(form, loadMetrics());

    form.addEventListener('input', (e) => {
      const t = e.target;
      if (!(t instanceof HTMLInputElement) && !(t instanceof HTMLSelectElement)) return;
      handleInput(form, t);
    });
    form.addEventListener('change', (e) => {
      const t = e.target;
      if (!(t instanceof HTMLInputElement) && !(t instanceof HTMLSelectElement)) return;
      handleInput(form, t);
    });

    const clearBtn = form.querySelector('[data-clear-metrics]') as HTMLButtonElement | null;
    clearBtn?.addEventListener('click', () => {
      if (!confirm('確定要清除所有輸入的資料嗎？')) return;
      clearMetrics();
    });

    onMetricsChange((m) => {
      // 其他來源（例如 clear）造成的變更，re-hydrate 表單
      hydrateForm(form, m);
    });
  });
</script>
