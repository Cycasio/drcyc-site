---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const faqs = [
  {
    q: '陳醫師有哪些看診地點？',
    a: '兩個地點，同一位醫師。(1) 義大醫院家庭暨社區醫學部 / 義大健診中心 / 義大減重中心：週一、週二上午高階健檢報告解說；週五上午家醫科門診；週五下午減重中心。(2) 旗山大政診所：每週五 18:00–21:00 夜診，提供家醫科、三高慢性病追蹤與藥物減重。',
    locations: [
      {
        symbol: 'local_hospital',
        name: '義大醫院',
        subtitle: '家醫科・健診中心・減重中心',
        slots: [
          { day: '週一', time: '上午', focus: '高階健檢 / 報告解說' },
          { day: '週二', time: '上午', focus: '高階健檢 / 報告解說' },
          { day: '週五', time: '上午', focus: '家醫科門診' },
          { day: '週五', time: '下午', focus: '減重中心' },
        ],
        bookingLabel: '義大線上掛號',
        bookingHref: 'https://webreg.edah.org.tw/Register/ChooseDoctorTime/2675',
        bookingSymbol: 'calendar_month',
      },
      {
        symbol: 'bedtime',
        name: '旗山大政診所',
        subtitle: '週五夜診',
        slots: [
          { day: '週五', time: '夜診', focus: '家醫 / 三高 / 減重' },
        ],
        extraNote: '18:00–21:00',
        bookingLabel: '07-662-2588',
        bookingHref: 'tel:+886766225588',
        bookingSymbol: 'call',
      },
    ],
  },
  {
    q: '猛健樂（Mounjaro）GLP-1 減重在哪邊比較方便？',
    a: '如果你住在旗山、美濃、田寮、內門，或是白天要上班不方便請假，週五晚上到旗山大政診所最順。如果你想搭配完整健檢一起做、或住在楠梓/左營/岡山/橋頭/燕巢一帶，義大減重中心比較近。兩邊都能做減重療程，不會因為換地點而中斷。',
  },
  {
    q: '陳醫師的專長有哪些？',
    a: '家庭醫學、肥胖醫學、運動醫學、職業醫學、骨質疏鬆、行為科學、實證醫學。持有家庭醫學、肥胖醫學、骨質疏鬆症三專科證照，榮獲國家醫療品質獎實證醫學類臨床組銀獎。',
  },
  {
    q: '什麼是行為科學導向的醫療？',
    a: '結合 COM-B 模型、動機式晤談等行為改變技術，幫助病患建立可持續的健康習慣，而非只開藥治療。核心理念：理解（Understand）→ 溝通（Communicate）→ 改變（Transform）。',
  },
  {
    q: '減重門診的方式？',
    a: '採用實證醫學方法，結合營養、行為科學、運動處方與藥物治療（含 Contrave、GLP-1 類如猛健樂），制定個人化減重策略。不是單靠一支針就解決，是整套可持續的生活改變。',
  },
  {
    q: '如何預約、聯絡陳醫師？',
    a: '義大醫院線上掛號：webreg.edah.org.tw（查「家庭醫學科 陳昱彰」）。旗山大政診所預約電話：07-662-2588（建議先致電確認名額）。其他聯絡：Facebook 粉專 @lazydr、電子信箱 cyc@edfm.org。',
  },
];
---

<Layout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-surface pt-12 pb-24 md:pt-20 md:pb-32">
    <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 z-10">
        <p class="inline-block bg-secondary/10 text-secondary px-4 py-1.5 rounded-full text-sm font-bold tracking-wide mb-6">Family Medicine × Behavioral Science</p>
        <h1 class="text-4xl md:text-6xl font-extrabold text-primary leading-tight tracking-tight mb-4 font-headline">
          陳昱彰 醫師
        </h1>
        <p class="text-xl md:text-2xl text-on-surface-variant mb-2 font-medium">Yu-Chang Chen, MD</p>
        <p class="text-lg text-on-surface-variant mb-8 max-w-xl chinese-line-height">
          家庭醫學・肥胖醫學・骨質疏鬆<br/>
          義大醫院主治醫師｜結合行為科學，協助您建立可持續的健康生活
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="https://webreg.edah.org.tw/Register/ChooseDoctorTime/2675"
            target="_blank"
            rel="noopener"
            class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-8 py-4 rounded-full font-bold text-lg shadow-lg hover:scale-[1.02] transition-transform no-underline"
          >
            立即預約掛號
          </a>
          <a
            href="/services"
            class="border border-primary/20 text-primary px-8 py-4 rounded-full font-bold text-lg hover:bg-primary-fixed-dim/20 transition-colors no-underline"
          >
            了解診療項目
          </a>
        </div>
      </div>
      <div class="lg:col-span-5 relative">
        <div class="absolute -top-10 -right-10 w-64 h-64 bg-secondary/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="relative rounded-3xl overflow-hidden aspect-[4/5] shadow-2xl transform lg:rotate-2">
          <img
            src="/images/portrait.jpg"
            alt="陳昱彰醫師"
            class="w-full h-full object-cover"
            width="400"
            height="500"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Service Highlights (Bento Grid) -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16">
        <span class="text-on-surface-variant text-sm font-bold tracking-[0.2em] uppercase">Services</span>
        <h2 class="text-4xl font-bold text-primary mt-2 font-headline">專業服務項目</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- 企業臨場健康服務 (large, col-span-2) -->
        <a href="/services" class="md:col-span-2 bg-surface-container-lowest p-10 rounded-3xl flex flex-col justify-between hover:bg-white transition-colors no-underline group">
          <div>
            <div class="w-14 h-14 bg-secondary/10 text-secondary rounded-2xl flex items-center justify-center mb-6">
              <span class="material-symbols-outlined" style="font-size:32px;">business_center</span>
            </div>
            <h3 class="text-2xl font-bold text-primary mb-4 font-headline">企業臨場健康服務</h3>
            <p class="text-on-surface-variant chinese-line-height text-lg">
              依據《職業安全衛生法》，提供專業臨場健康服務：勞工健康保護四大計畫、工作環境危害評估、員工健康管理與追蹤。協助企業法規遵循，打造員工健康管理系統。
            </p>
          </div>
          <div class="mt-8 flex items-center text-secondary font-bold cursor-pointer">
            了解詳情 →
          </div>
        </a>

        <!-- 義大健檢完整指南 (small dark primary card) -->
        <a href="/health-checkup/" class="bg-primary text-on-primary p-10 rounded-3xl flex flex-col justify-between no-underline">
          <div>
            <div class="w-14 h-14 bg-white/10 text-white rounded-2xl flex items-center justify-center mb-6">
              <span class="material-symbols-outlined" style="font-size:32px;">science</span>
            </div>
            <h3 class="text-2xl font-bold mb-4 font-headline">義大健檢完整指南</h3>
            <p class="text-on-primary-container chinese-line-height">
              義大醫院 16 個健檢套餐一次比完，附 USPSTF 實證點評、健檢前準備、清腸藥時程與交通資訊。我幫你用家醫科的角度，告訴你哪個方案適合你。
            </p>
          </div>
          <span class="text-sm font-medium opacity-60">實證選購・2026 更新</span>
        </a>

        <!-- 減重管理門診 — 兩地點 (teal secondary-container card) -->
        <a href="/services" class="bg-secondary-container text-on-secondary-container p-10 rounded-3xl flex flex-col justify-between no-underline">
          <div>
            <div class="w-14 h-14 bg-on-secondary-container/10 text-on-secondary-container rounded-2xl flex items-center justify-center mb-6">
              <span class="material-symbols-outlined" style="font-size:32px;">monitor_weight</span>
            </div>
            <h3 class="text-2xl font-bold mb-4 font-headline">減重管理門診</h3>
            <p class="chinese-line-height mb-4">
              整合飲食、運動、壓力管理、睡眠調整與藥物治療（含 Contrave、GLP-1 類），以行為科學方法協助建立可持續的健康習慣。
            </p>
            <div class="space-y-2 text-sm">
              <div>📍 <strong>義大減重中心</strong>・週五下午</div>
              <div>📍 <strong>旗山大政診所</strong>・週五夜診 18:00–21:00</div>
            </div>
          </div>
          <span class="text-sm font-bold mt-4 block">兩個地點,同一位醫師 →</span>
        </a>

        <!-- 旗山大政診所夜診卡片 -->
        <a href="/qishan-clinic/" class="md:col-span-2 bg-surface-container-lowest p-10 rounded-3xl flex flex-col md:flex-row items-start md:items-center gap-10 hover:bg-white transition-colors no-underline group border border-outline-variant/10">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="material-symbols-outlined text-secondary" style="font-size:28px;">bedtime</span>
              <span class="text-xs font-bold tracking-widest text-secondary uppercase">週五夜診・旗山・美濃・田寮・內門</span>
            </div>
            <h3 class="text-2xl font-bold text-primary mb-3 font-headline">旗山大政診所・週五夜診</h3>
            <p class="text-on-surface-variant chinese-line-height">
              下班後 18:00–21:00 看診,不用特地請假跑義大。<strong>藥物減重(含 GLP-1)、三高慢性病追蹤、家醫科</strong>門診,
              由陳醫師本人親自駐診。適合住在旗山、美濃、田寮、內門一帶的居民,以及白天要上班的朋友。
            </p>
            <div class="mt-4 flex flex-wrap gap-2 text-xs">
              <span class="px-3 py-1 bg-surface-container-high rounded-full font-medium">週五 18:00–21:00</span>
              <span class="px-3 py-1 bg-surface-container-high rounded-full font-medium">藥物減重</span>
              <span class="px-3 py-1 bg-surface-container-high rounded-full font-medium">三高處方</span>
              <span class="px-3 py-1 bg-surface-container-high rounded-full font-medium">電話預約 07-662-2588</span>
            </div>
          </div>
          <span class="text-secondary font-bold text-sm whitespace-nowrap">查看夜診資訊 →</span>
        </a>

        <!-- 衛教演講 / 企業健康講座 (col-span-1) -->
        <a href="/speaking/" class="bg-on-secondary-container text-secondary-container p-10 rounded-3xl flex flex-col justify-between no-underline hover:opacity-95 transition-opacity">
          <div>
            <div class="w-14 h-14 bg-white/10 text-white rounded-2xl flex items-center justify-center mb-6">
              <span class="material-symbols-outlined" style="font-size:32px;">campaign</span>
            </div>
            <h3 class="text-2xl font-bold mb-4 font-headline">衛教演講<br/>企業健康講座</h3>
            <p class="chinese-line-height text-sm opacity-90">
              曾赴中鋼、中油、國巨、李長榮、英特格、麥當勞、東海/義大/高科大/中正大學及多所機關學校演講。主題含減重、三高、骨鬆、職場健康、人因與行為科學。
            </p>
          </div>
          <span class="text-sm font-bold mt-4 block">查看講題與邀約 →</span>
        </a>

        <!-- 社區健康營造 (col-span-2) -->
        <a href="/services" class="md:col-span-2 bg-surface-container-lowest p-10 rounded-3xl flex flex-col md:flex-row items-start md:items-center gap-10 hover:bg-white transition-colors no-underline group">
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-primary mb-4 font-headline">社區健康營造</h3>
            <p class="text-on-surface-variant chinese-line-height max-w-2xl">
              以居民參與為核心，推動由下而上的社區健康計畫。深入社區提供健康講座、諮詢與居家醫療評估，讓專業醫療資源不再有距離感。
            </p>
            <div class="mt-6 flex gap-4 flex-wrap">
              <span class="px-3 py-1 bg-surface-container-high rounded-full text-sm font-medium">健康講座</span>
              <span class="px-3 py-1 bg-surface-container-high rounded-full text-sm font-medium">居家醫療評估</span>
              <span class="px-3 py-1 bg-surface-container-high rounded-full text-sm font-medium">籌備中</span>
            </div>
          </div>
          <div class="text-secondary font-bold whitespace-nowrap hidden md:block">了解更多 →</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Section -->
  <section class="py-24 max-w-7xl mx-auto px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-primary font-headline">為什麼選擇陳醫師？</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center px-6">
        <span class="material-symbols-outlined text-secondary mb-4 block mx-auto" style="font-size:48px;">workspace_premium</span>
        <h3 class="text-xl font-bold text-primary mb-3 font-headline">國家級實證醫學獎項</h3>
        <p class="text-on-surface-variant chinese-line-height">國家醫療品質獎 EBM 臨床組銀獎，SCI 期刊論文發表，以研究實證為臨床決策基礎。</p>
      </div>
      <div class="text-center px-6">
        <span class="material-symbols-outlined text-secondary mb-4 block mx-auto" style="font-size:48px;">verified</span>
        <h3 class="text-xl font-bold text-primary mb-3 font-headline">三專科整合照護</h3>
        <p class="text-on-surface-variant chinese-line-height">家庭醫學、肥胖醫學、骨質疏鬆三專科認證，一站式處理您的多面向健康問題。</p>
      </div>
      <div class="text-center px-6">
        <span class="material-symbols-outlined text-secondary mb-4 block mx-auto" style="font-size:48px;">psychology</span>
        <h3 class="text-xl font-bold text-primary mb-3 font-headline">行為科學驅動改變</h3>
        <p class="text-on-surface-variant chinese-line-height">不只開藥治療，運用行為科學方法協助您建立可持續的健康習慣，從根本改善生活型態。</p>
      </div>
    </div>
  </section>

  <!-- Featured Blog Posts -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex justify-between items-end mb-16">
        <div>
          <span class="text-on-surface-variant text-sm font-bold tracking-[0.2em] uppercase">Health Blog</span>
          <h2 class="text-4xl font-bold text-primary mt-2 font-headline">衛教專欄</h2>
        </div>
        <a class="text-secondary font-bold hover:underline underline-offset-8 transition-all no-underline" href="/blog">查看所有文章</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            image={post.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-3xl mx-auto px-8">
      <h2 class="text-4xl font-bold text-primary mb-12 text-center font-headline">常見問題</h2>
      <div class="space-y-4">
        {faqs.map((f) => (
          <details class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm group">
            <summary class="px-8 py-6 cursor-pointer font-bold text-primary text-lg list-none flex items-center justify-between">
              {f.q}
              <span class="text-secondary transition-transform group-open:rotate-180 inline-block">▼</span>
            </summary>
            <div class="px-8 pb-6">
              {f.locations ? (
                <>
                  <p class="text-on-surface-variant chinese-line-height mb-5">兩個地點，同一位醫師、同樣的治療邏輯，按居住地與時段方便度選擇。</p>
                  <div class="grid md:grid-cols-2 gap-4">
                    {f.locations.map((loc) => (
                      <div class="rounded-xl border border-outline-variant/30 bg-surface-container-lowest p-5">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="material-symbols-outlined text-secondary" style="font-size:22px;">{loc.symbol}</span>
                          <h4 class="font-bold text-primary text-base">{loc.name}</h4>
                        </div>
                        <p class="text-xs text-on-surface-variant mb-4">{loc.subtitle}</p>
                        <ul class="space-y-2 mb-4">
                          {loc.slots.map((s) => (
                            <li class="flex items-start gap-3 text-sm">
                              <span class="font-semibold text-primary whitespace-nowrap min-w-[60px]">{s.day} {s.time}</span>
                              <span class="text-on-surface-variant flex-1">{s.focus}</span>
                            </li>
                          ))}
                        </ul>
                        {loc.extraNote && (
                          <p class="text-xs text-secondary font-bold mb-3 flex items-center gap-1">
                            <span class="material-symbols-outlined" style="font-size:16px;">schedule</span>
                            {loc.extraNote}
                          </p>
                        )}
                        <a
                          href={loc.bookingHref}
                          target={loc.bookingHref.startsWith('http') ? '_blank' : undefined}
                          rel={loc.bookingHref.startsWith('http') ? 'noopener' : undefined}
                          class="inline-flex items-center gap-2 text-sm font-bold text-secondary hover:underline no-underline"
                        >
                          <span class="material-symbols-outlined" style="font-size:18px;">{loc.bookingSymbol}</span>
                          {loc.bookingLabel} →
                        </a>
                      </div>
                    ))}
                  </div>
                </>
              ) : (
                <p class="text-on-surface-variant chinese-line-height">{f.a}</p>
              )}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-8">
      <div class="bg-primary-container rounded-[2rem] p-12 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-primary/50 to-transparent"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 font-headline">準備好開始您的健康旅程了嗎？</h2>
          <p class="text-on-primary-container text-lg mb-10 max-w-2xl mx-auto chinese-line-height">
            兩個看診地點，同一位醫師。選一個你方便的地方開始。
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a
              href="https://webreg.edah.org.tw/Register/ChooseDoctorTime/2675"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 bg-secondary text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-on-secondary-container transition-all shadow-xl no-underline"
            >
              <span class="material-symbols-outlined" style="font-size:22px;">calendar_month</span>
              義大線上掛號
            </a>
            <a
              href="tel:+886766225588"
              class="inline-flex items-center gap-2 bg-white/10 border border-white/40 text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-white/20 transition-all no-underline"
            >
              <span class="material-symbols-outlined" style="font-size:22px;">call</span>
              旗山大政 07-662-2588
            </a>
          </div>
          <p class="text-on-primary-container/70 text-xs mt-6">
            義大：週一、二、五上午・週五下午減重中心｜旗山大政：每週五 18:00–21:00 夜診
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
