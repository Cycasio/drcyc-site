---
import Layout from '../layouts/Layout.astro';
import {
  PACKAGES,
  EVIDENCE,
  LOW_EVIDENCE_NOTE,
  GENERAL_PREP,
  ENDO_PREP,
  BOWEL_PREP_DRUGS,
  LOCATION,
  TRANSIT_CAR,
  TRANSIT_PUBLIC,
  FAQ,
  LAST_UPDATED,
  OFFICIAL_URL,
  BOOKING_PHONE,
  BOOKING_EXTENSIONS,
} from '../data/checkup';

const SITE = 'https://www.drcyc.io';
const pageUrl = `${SITE}/health-checkup/`;

const publicPackages = PACKAGES.filter((p) => p.group === '公教人員專案');
const premiumPackages = PACKAGES.filter((p) => p.group === '健診中心精選');

const fmtPrice = (n: number) => `$${n.toLocaleString('en-US')}`;

const medicalWebPage = {
  '@type': 'MedicalWebPage',
  '@id': `${pageUrl}#webpage`,
  url: pageUrl,
  name: '義大醫院健檢套餐完整指南 2026',
  description:
    '義大醫院家醫科陳昱彰醫師整理的 16 個健檢套餐完整比較,含 USPSTF 實證醫學點評、健檢前準備、清腸藥 SOP、交通與預約資訊。',
  datePublished: '2026-04-13',
  dateModified: LAST_UPDATED,
  lastReviewed: LAST_UPDATED,
  reviewedBy: { '@id': `${SITE}/#person` },
  author: { '@id': `${SITE}/#person` },
  publisher: { '@id': `${SITE}/#person` },
  about: { '@type': 'MedicalProcedure', name: '健康檢查 Health Checkup' },
  specialty: 'FamilyPractice',
  inLanguage: 'zh-Hant',
  // Speakable: 朗讀 FAQ 答案、套餐標題、實證醫學摘要
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'h2', '[data-speakable="true"]'],
  },
};

// USPSTF 評等專有名詞（DefinedTermSet）— 讓 AI 理解這些是專業術語
const uspstfTermSet = {
  '@type': 'DefinedTermSet',
  '@id': `${pageUrl}#uspstf-grades`,
  name: 'USPSTF 預防服務工作小組建議等級',
  inDefinedTermSet: 'https://www.uspreventiveservicestaskforce.org/uspstf/grade-definitions',
  hasDefinedTerm: [
    {
      '@type': 'DefinedTerm',
      '@id': `${pageUrl}#uspstf-grade-a`,
      name: 'Grade A',
      description: 'USPSTF 強烈建議該預防服務。有高度確信淨效益顯著。',
      termCode: 'A',
      inDefinedTermSet: { '@id': `${pageUrl}#uspstf-grades` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${pageUrl}#uspstf-grade-b`,
      name: 'Grade B',
      description: 'USPSTF 建議該預防服務。有高度確信淨效益中等,或中度確信淨效益顯著。',
      termCode: 'B',
      inDefinedTermSet: { '@id': `${pageUrl}#uspstf-grades` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${pageUrl}#uspstf-grade-c`,
      name: 'Grade C',
      description: 'USPSTF 建議僅在個別情況下進行,根據專業判斷與病人偏好決定。淨效益小。',
      termCode: 'C',
      inDefinedTermSet: { '@id': `${pageUrl}#uspstf-grades` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${pageUrl}#uspstf-grade-d`,
      name: 'Grade D',
      description: 'USPSTF 不建議該預防服務。有中度或高度確信此服務無淨效益,或可能造成傷害。',
      termCode: 'D',
      inDefinedTermSet: { '@id': `${pageUrl}#uspstf-grades` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${pageUrl}#uspstf-grade-i`,
      name: 'I Statement',
      description: 'USPSTF 認為目前證據不足以評估該預防服務的利弊平衡。',
      termCode: 'I',
      inDefinedTermSet: { '@id': `${pageUrl}#uspstf-grades` },
    },
  ],
};

const itemListSchema = {
  '@type': 'ItemList',
  '@id': `${pageUrl}#packagelist`,
  name: '義大醫院健診中心套餐',
  numberOfItems: PACKAGES.length,
  itemListElement: PACKAGES.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${p.name}（${p.theme}）`,
    url: `${pageUrl}#pkg-${p.id}`,
    item: {
      '@type': 'MedicalProcedure',
      '@id': `${pageUrl}#pkg-${p.id}-procedure`,
      name: p.name,
      description: p.theme,
      url: `${pageUrl}#pkg-${p.id}`,
      procedureType: 'Diagnostic',
      offers: {
        '@type': 'Offer',
        price: p.price.toString(),
        priceCurrency: 'TWD',
        availability: 'https://schema.org/InStock',
        seller: {
          '@type': 'Hospital',
          name: '義大醫院',
          url: OFFICIAL_URL,
        },
        url: `${pageUrl}#pkg-${p.id}`,
      },
      review: {
        '@type': 'Review',
        '@id': `${pageUrl}#pkg-${p.id}-review`,
        itemReviewed: { '@id': `${pageUrl}#pkg-${p.id}-procedure` },
        author: { '@id': `${SITE}/#person` },
        publisher: { '@id': `${SITE}/#person` },
        datePublished: LAST_UPDATED,
        reviewBody: p.chenNote,
      },
    },
  })),
};

const faqSchema = {
  '@type': 'FAQPage',
  '@id': `${pageUrl}#faq`,
  mainEntity: FAQ.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['[data-faq-question]', '[data-faq-answer]'],
  },
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: '義大健檢指南', item: pageUrl },
  ],
};

const bowelPrepHowToSchemas = BOWEL_PREP_DRUGS.map((d) => ({
  '@type': 'HowTo',
  '@id': `${pageUrl}#howto-${d.englishName.toLowerCase().replace(/\s+/g, '-')}`,
  name: `${d.name} ${d.englishName} 服藥時程`,
  description: `義大醫院健診中心無痛大腸鏡前清腸藥「${d.name}（${d.englishName}，${d.generic}）」服藥時程,依藥品仿單與醫院衛教單整理。`,
  inLanguage: 'zh-Hant',
  totalTime: 'PT12H',
  supply: [
    { '@type': 'HowToSupply', name: `${d.name}（${d.englishName}）` },
    { '@type': 'HowToSupply', name: '白開水或無渣流質' },
  ],
  tool: [{ '@type': 'HowToTool', name: '量杯 / 飲水容器' }],
  step: d.steps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.time,
    text: s.action,
  })),
  author: { '@id': `${SITE}/#person` },
  publisher: { '@id': `${SITE}/#person` },
  about: { '@type': 'MedicalProcedure', name: '無痛大腸鏡前清腸 Bowel Preparation' },
}));

const title = '義大醫院健檢套餐完整指南 2026｜家醫科陳昱彰醫師實證比較';
const description =
  '高雄義大醫院健診中心 2025–2026 年度 16 個健檢套餐完整比較,含公教人員專案 A–H 與精選套餐價格、項目、適合對象、陳醫師 USPSTF 實證點評、健檢前準備、清腸藥 SOP、交通與預約資訊。';
---

<Layout
  title={title}
  description={description}
  jsonLd={[medicalWebPage, uspstfTermSet, itemListSchema, faqSchema, breadcrumbSchema, ...bowelPrepHowToSchemas]}
>
  <main class="max-w-6xl mx-auto px-6 md:px-10 py-12">
    <!-- Breadcrumb -->
    <nav class="text-xs text-slate-500 mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-teal-700">首頁</a>
      <span class="mx-2">／</span>
      <span>義大健檢指南</span>
    </nav>

    <!-- Hero -->
    <header class="mb-10">
      <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-3">
        Health Checkup Guide · 2025–2026
      </p>
      <h1 class="text-3xl md:text-5xl font-extrabold text-blue-950 leading-tight mb-5">
        義大醫院健檢套餐完整指南
      </h1>
      <p class="text-lg text-slate-700 leading-relaxed max-w-3xl chinese-line-height">
        我是義大醫院家醫科主治醫師<strong>陳昱彰</strong>。這一頁把義大健診中心 2025–2026
        年度的 <strong>16 個健檢套餐</strong>整理成一張可以一次讀完的比較表,並在每個方案旁附上
        <strong>USPSTF 實證醫學點評</strong>,告訴你什麼人真的會受益、什麼情況可以省下來。
      </p>
    </header>

    <!-- Disclaimer -->
    <aside class="rounded-xl border-l-4 border-teal-600 bg-teal-50/60 p-5 mb-12 text-sm text-slate-700 leading-relaxed">
      <p class="mb-2">
        <strong class="text-teal-800">資料來源聲明</strong> —
        本頁資訊整理自義大醫院健診中心官方公告,<strong>最後核對日期 {LAST_UPDATED}</strong>。
        實際價格、項目與最新方案以
        <a href={OFFICIAL_URL} target="_blank" rel="noopener" class="text-teal-700 underline"
          >義大醫院官方公告</a
        >為準。
      </p>
      <p>
        本文由義大家庭暨社區醫學部陳昱彰醫師整理,<strong>不收取任何轉介佣金</strong
        >,亦非任何形式的廣告文宣。撰寫目的是協助民眾在有實證醫學觀點下選擇適合自己的健檢方案。
      </p>
    </aside>

    <!-- 3-step how-to -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-6">三步驟選對你的健檢方案</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <div class="text-3xl font-extrabold text-teal-700 mb-2">1</div>
          <h3 class="font-bold text-blue-950 mb-1">看自己的風險</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            年齡、吸菸史、家族病史、慢性病,決定了你該優先篩什麼。實證醫學章節有完整清單。
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <div class="text-3xl font-extrabold text-teal-700 mb-2">2</div>
          <h3 class="font-bold text-blue-950 mb-1">對照套餐 + 點評</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            每個方案旁邊都有陳醫師的一段話,告訴你這個套餐適合誰、哪些項目真的值得。
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <div class="text-3xl font-extrabold text-teal-700 mb-2">3</div>
          <h3 class="font-bold text-blue-950 mb-1">預約 + 指定醫師解說</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            致電 {BOOKING_PHONE} 分機 {BOOKING_EXTENSIONS.join(' / ')},可直接指定由陳醫師解說報告。
          </p>
        </div>
      </div>
    </section>

    <!-- USPSTF Evidence -->
    <section id="evidence" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-3">實證醫學觀點:什麼檢查「真的」有用?</h2>
      <p class="text-slate-700 leading-relaxed mb-6 chinese-line-height">
        醫學中心的健檢型錄動輒 30–50 項,但真正有實證支持的篩檢項目其實不多。美國預防服務工作小組(
        <strong>USPSTF</strong>)把篩檢建議分成 A / B / C / D / I 五個等級,A 和 B 代表「證據充足,建議執行」。
        挑健檢時,讓 A/B 等級的項目先被涵蓋,再看其他附加內容有沒有符合你的個別需求 —
        這是最省錢也最不容易被過度診斷綁架的方法。
      </p>

      <div class="overflow-x-auto rounded-xl border border-slate-200 mb-4">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-blue-950">
            <tr>
              <th class="text-left p-3 font-bold">項目</th>
              <th class="text-center p-3 font-bold w-16">等級</th>
              <th class="text-left p-3 font-bold">建議族群</th>
            </tr>
          </thead>
          <tbody>
            {EVIDENCE.map((e) => (
              <tr class="border-t border-slate-100 align-top">
                <td class="p-3 font-semibold text-blue-950">
                  {e.name}
                  {e.note && <p class="font-normal text-slate-500 text-xs mt-1 leading-relaxed">{e.note}</p>}
                </td>
                <td class="p-3 text-center">
                  <span class="inline-block rounded-full bg-teal-100 text-teal-800 font-bold px-3 py-1 text-xs">
                    {e.grade}
                  </span>
                </td>
                <td class="p-3 text-slate-700 leading-relaxed">{e.population}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed chinese-line-height">
        ⚠️ {LOW_EVIDENCE_NOTE}
      </p>
    </section>

    <!-- Package Comparison Summary -->
    <section id="comparison" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-6">16 個套餐一次看完</h2>
      <div class="overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-blue-950">
            <tr>
              <th class="text-left p-3 font-bold">套餐</th>
              <th class="text-left p-3 font-bold">主題</th>
              <th class="text-right p-3 font-bold">價格</th>
              <th class="text-left p-3 font-bold">時長</th>
            </tr>
          </thead>
          <tbody>
            {PACKAGES.map((p) => (
              <tr class="border-t border-slate-100 hover:bg-slate-50/50">
                <td class="p-3">
                  <a href={`#pkg-${p.id}`} class="font-semibold text-teal-700 hover:underline no-underline">
                    {p.name}
                  </a>
                  <p class="text-xs text-slate-500">{p.group}</p>
                </td>
                <td class="p-3 text-slate-700">{p.theme}</td>
                <td class="p-3 text-right font-mono font-bold text-blue-950 price-tag">{fmtPrice(p.price)}</td>
                <td class="p-3 text-slate-600 text-xs">{p.duration}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Detailed packages: public -->
    <section id="packages-public" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-2">公教人員專案 A–H</h2>
      <p class="text-sm text-slate-600 mb-6">$8,900–$18,800｜同等級項目最便宜的選擇</p>
      <div class="space-y-6">
        {publicPackages.map((p) => (
          <article id={`pkg-${p.id}`} class="rounded-xl border border-slate-200 bg-white p-6 scroll-mt-24">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
              <div>
                <div class="flex items-center gap-3 mb-1">
                  <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-teal-700 text-white font-bold text-sm">
                    {p.id}
                  </span>
                  <h3 class="text-xl font-bold text-blue-950">{p.name}</h3>
                </div>
                <p class="text-sm text-slate-600">{p.theme}・{p.duration}</p>
              </div>
              <div class="text-right">
                <p class="font-mono font-extrabold text-2xl text-blue-950 price-tag">{fmtPrice(p.price)}</p>
              </div>
            </div>
            <p class="text-sm text-slate-700 mb-4">
              <strong class="text-blue-950">適合誰:</strong> {p.bestFor}
            </p>
            <ul class="list-disc list-inside text-sm text-slate-700 space-y-1 mb-4 chinese-line-height">
              {p.highlights.map((h) => <li>{h}</li>)}
            </ul>
            <div class="border-l-4 border-teal-600 bg-teal-50/50 p-4 rounded-r-lg">
              <p class="text-sm text-blue-950 leading-relaxed chinese-line-height">
                <strong>🩺 陳醫師點評:</strong> {p.chenNote}
              </p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Detailed packages: premium -->
    <section id="packages-premium" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-2">健診中心精選套餐</h2>
      <p class="text-sm text-slate-600 mb-6">$15,000–$196,000｜加入高階影像或功能醫學項目</p>
      <div class="space-y-6">
        {premiumPackages.map((p) => (
          <article id={`pkg-${p.id}`} class="rounded-xl border border-slate-200 bg-white p-6 scroll-mt-24">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
              <div>
                <h3 class="text-xl font-bold text-blue-950 mb-1">{p.name}</h3>
                <p class="text-sm text-slate-600">{p.theme}・{p.duration}</p>
              </div>
              <div class="text-right">
                <p class="font-mono font-extrabold text-2xl text-blue-950 price-tag">{fmtPrice(p.price)}</p>
              </div>
            </div>
            <p class="text-sm text-slate-700 mb-4">
              <strong class="text-blue-950">適合誰:</strong> {p.bestFor}
            </p>
            <ul class="list-disc list-inside text-sm text-slate-700 space-y-1 mb-4 chinese-line-height">
              {p.highlights.map((h) => <li>{h}</li>)}
            </ul>
            <div class="border-l-4 border-teal-600 bg-teal-50/50 p-4 rounded-r-lg">
              <p class="text-sm text-blue-950 leading-relaxed chinese-line-height">
                <strong>🩺 陳醫師點評:</strong> {p.chenNote}
              </p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Prep Section -->
    <section id="prep" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-6">健檢前準備</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <h3 class="font-bold text-blue-950 mb-3">一般注意事項</h3>
          <ul class="list-disc list-inside text-sm text-slate-700 space-y-2 chinese-line-height">
            {GENERAL_PREP.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <h3 class="font-bold text-blue-950 mb-3">含無痛胃腸鏡(H、舒適健檢)</h3>
          <ul class="list-disc list-inside text-sm text-slate-700 space-y-2 chinese-line-height">
            {ENDO_PREP.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      <h3 class="text-lg font-bold text-blue-950 mt-8 mb-4">三種清腸藥的服用時程</h3>
      <p class="text-sm text-slate-600 mb-6">
        義大健診中心依個別情況開立下列其中一種。以下時程依各藥品仿單與醫院衛教單整理,實際服藥指示請以健診中心開立的單張與專人說明為準。
      </p>
      <div class="grid lg:grid-cols-3 gap-5">
        {BOWEL_PREP_DRUGS.map((d) => (
          <article id={`prep-${d.englishName.toLowerCase().replace(/\s+/g, '-')}`} class="rounded-2xl border border-slate-200 bg-white p-5 scroll-mt-24">
            <header class="mb-4 pb-3 border-b border-slate-100">
              <h4 class="text-lg font-bold text-blue-950">
                {d.name} <span class="text-sm text-slate-500 font-normal">{d.englishName}</span>
              </h4>
              <p class="text-xs text-slate-500 mt-1">{d.generic}</p>
            </header>
            <ol class="space-y-3 text-sm text-slate-700 chinese-line-height">
              {d.steps.map((s, i) => (
                <li class="flex gap-3">
                  <span class="shrink-0 w-6 h-6 rounded-full bg-teal-50 text-teal-700 text-xs font-bold flex items-center justify-center mt-0.5">{i + 1}</span>
                  <div>
                    <div class="font-semibold text-blue-950 text-xs uppercase tracking-wide mb-0.5">{s.time}</div>
                    <div>{s.action}</div>
                  </div>
                </li>
              ))}
            </ol>
            <aside class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-600 chinese-line-height">
              <p class="font-semibold text-blue-950 mb-1">⚠️ 注意</p>
              <p>{d.note}</p>
            </aside>
            <p class="mt-3 text-[10px] text-slate-400">{d.source}</p>
          </article>
        ))}
      </div>
      <p class="text-xs text-slate-500 mt-4 chinese-line-height">
        <strong>共通禁忌</strong>:腎臟疾病、先天性巨結腸症、腸阻塞或腸穿孔、嚴重肝硬化合併腹水、癲癇病史、孕婦或無法配合大量飲水者,請於預約時告知,健診中心會評估改用其他清腸劑。如服用抗血小板或抗凝血劑(Aspirin、Clopidogrel、Warfarin、Dabigatran、Rivaroxaban、Apixaban 等),請與原處方醫師討論是否可停藥 7 天。
      </p>
    </section>

    <!-- Transit -->
    <section id="transit" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-4">交通資訊</h2>
      <p class="text-slate-700 mb-6">
        <strong>{LOCATION}</strong>
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <h3 class="font-bold text-blue-950 mb-3">🚗 自行開車</h3>
          <ul class="list-disc list-inside text-sm text-slate-700 space-y-2 chinese-line-height">
            {TRANSIT_CAR.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <h3 class="font-bold text-blue-950 mb-3">🚆 大眾運輸</h3>
          <ul class="list-disc list-inside text-sm text-slate-700 space-y-2 chinese-line-height">
            {TRANSIT_PUBLIC.map((item) => <li>{item}</li>)}
          </ul>
          <p class="text-xs text-slate-500 mt-3">※ 當日含無痛胃腸鏡者,務必由家人接送或搭大眾運輸。</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-6">常見問題</h2>
      <div class="space-y-3">
        {FAQ.map((f) => (
          <details class="group rounded-xl border border-slate-200 bg-white">
            <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-blue-950 flex justify-between items-center">
              <span>{f.q}</span>
              <span class="text-teal-700 text-xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-slate-700 leading-relaxed chinese-line-height">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="rounded-2xl bg-gradient-to-br from-blue-950 to-teal-700 text-white p-10 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">預約時可直接指定陳醫師解說報告</h2>
      <p class="text-white/80 mb-4 max-w-2xl mx-auto leading-relaxed chinese-line-height">
        健檢拿到一份報告只是起點。具備家庭醫學、實證醫學與行為科學訓練的醫師,能把數字跟你的生活型態、病史連結起來,找出具體可以改變的切入點 —
        這才是把健檢花的錢真正用在「變健康」上。
      </p>
      <p class="text-white/60 text-sm mb-6 max-w-xl mx-auto chinese-line-height">
        週一、週二上午為高階健檢報告解說時段。若您已完成高階健檢並希望由陳醫師親自解說報告，請透過健檢中心安排預約；此時段不開放一般門診掛號。
      </p>
      <div class="flex flex-wrap gap-3 justify-center text-sm">
        <a
          href={`tel:+886${BOOKING_PHONE.replace(/-/g, '').substring(1)}`}
          class="inline-block bg-white text-blue-950 px-6 py-3 rounded-full font-bold hover:opacity-90 no-underline"
        >
          📞 {BOOKING_PHONE}
        </a>
        <a
          href="mailto:cyc@edfm.org"
          class="inline-block bg-white/10 border border-white/40 text-white px-6 py-3 rounded-full font-bold hover:bg-white/20 no-underline"
        >
          📧 cyc@edfm.org
        </a>
        <a
          href="https://www.facebook.com/lazydr"
          target="_blank"
          rel="noopener"
          class="inline-block bg-white/10 border border-white/40 text-white px-6 py-3 rounded-full font-bold hover:bg-white/20 no-underline"
        >
          Facebook @lazydr
        </a>
      </div>
      <p class="text-xs text-white/60 mt-6">
        健診中心分機 {BOOKING_EXTENSIONS.join(' / ')}｜週一至週五 07:30–16:00、週六 07:30–12:00
      </p>
    </section>
  </main>
</Layout>
