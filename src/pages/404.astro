---
import Layout from '../layouts/Layout.astro';

const popular = [
  { href: '/health-checkup/', label: '義大健檢指南', emoji: '🩺' },
  { href: '/blog/', label: '衛教專欄', emoji: '📖' },
  { href: '/tools/', label: '健康工具', emoji: '🧮' },
  { href: '/services/', label: '服務項目', emoji: '🏥' },
  { href: '/about/', label: '關於陳醫師', emoji: '👨‍⚕️' },
];
---

<Layout
  title="找不到頁面 (404)｜陳昱彰醫師"
  description="您要找的頁面不存在或已移動。"
  noindex={true}
>
  <main id="main" class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="text-7xl font-extrabold text-primary font-headline mb-4">404</p>
    <h1 class="text-2xl md:text-3xl font-bold text-blue-950 mb-4 font-headline">找不到這個頁面</h1>
    <p class="text-slate-600 chinese-line-height mb-10">
      您要找的頁面可能已經移動、改名或不存在。以下是幾個常用頁面，或回到首頁重新開始。
    </p>

    <div class="grid sm:grid-cols-2 gap-3 mb-10 text-left">
      {popular.map((p) => (
        <a
          href={p.href}
          class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-slate-200 hover:border-primary hover:shadow-md transition-all no-underline"
        >
          <span class="text-2xl">{p.emoji}</span>
          <span class="font-bold text-blue-950">{p.label}</span>
        </a>
      ))}
    </div>

    <a
      href="/"
      class="inline-block bg-primary text-on-primary px-8 py-3 rounded-full font-bold hover:opacity-90 transition-opacity no-underline"
    >
      回到首頁
    </a>
  </main>
</Layout>
