---
import Layout from '../../layouts/Layout.astro';
import { TOOLS, TOOL_GROUPS, TOOLS_SITE, TOOLS_DASHBOARD_URL } from '../../data/tools';

const title = '醫療計算機｜減重 / 肥胖 / 代謝指標｜陳昱彰醫師';
const description = '義大醫院家醫科陳昱彰醫師整理的線上醫療計算機合集：BMI、TDEE、體脂率、腰圍身高比、GLP-1 適應症、減重進度等 8 個計算機，採用衛福部國健署與國際公認標準，所有資料只在你的瀏覽器，不上傳。';

const collectionSchema = {
  '@type': 'CollectionPage',
  '@id': `${TOOLS_SITE}/tools/#collection`,
  url: `${TOOLS_SITE}/tools/`,
  name: '醫療計算機合集',
  description,
  inLanguage: 'zh-Hant',
  hasPart: TOOLS.map((t) => ({
    '@type': 'SoftwareApplication',
    name: t.pageHeading,
    url: t.url,
    applicationCategory: 'HealthApplication',
  })),
};

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${TOOLS_SITE}/` },
    { '@type': 'ListItem', position: 2, name: '醫療計算機', item: `${TOOLS_SITE}/tools/` },
  ],
};
---

<Layout title={title} description={description} jsonLd={[collectionSchema, breadcrumb]}>
  <main class="max-w-6xl mx-auto px-6 md:px-10 py-12">
    <nav class="text-xs text-slate-500 mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-teal-700">首頁</a>
      <span class="mx-2">／</span>
      <span>醫療計算機</span>
    </nav>

    <header class="mb-10">
      <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-3">Medical Calculators · 陳昱彰醫師</p>
      <h1 class="text-3xl md:text-4xl font-bold text-blue-950 mb-3 font-headline">
        醫療計算機合集
      </h1>
      <p class="text-slate-600 chinese-line-height max-w-3xl">
        家醫科 / 肥胖醫學常用的 8 個臨床指標，採用衛福部國民健康署與國際公認標準，附臨床點評。所有輸入只儲存在您的瀏覽器，不上傳任何資料。
      </p>
    </header>

    <section class="mb-12">
      <a
        href="/tools/dashboard/"
        class="block rounded-3xl bg-gradient-to-br from-primary to-primary-container text-on-primary p-6 md:p-8 hover:opacity-95 transition-opacity no-underline"
      >
        <div class="flex items-start gap-4">
          <span class="text-4xl">🩺</span>
          <div class="flex-1">
            <p class="text-xs font-bold uppercase tracking-widest mb-2 opacity-80">推薦入口</p>
            <h2 class="text-xl md:text-2xl font-bold mb-2 font-headline">減重綜合儀表板</h2>
            <p class="text-on-primary-container chinese-line-height">
              一頁全部算完——BMI、理想體重、TDEE、體脂、腰圍指標、GLP-1 評估、減重進度。診間可直接列印給患者帶走。
            </p>
          </div>
        </div>
      </a>
    </section>

    {TOOL_GROUPS.map((group) => (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-blue-950 mb-4 font-headline">{group.category}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {group.tools.map((t) => (
            <a
              href={t.url.replace(TOOLS_SITE, '')}
              class="block p-5 rounded-2xl bg-white border border-outline-variant hover:border-primary hover:shadow-md transition-all no-underline"
            >
              <span class="text-3xl">{t.emoji}</span>
              <h3 class="text-base font-bold text-blue-950 mt-3 font-headline">{t.shortLabel}</h3>
              <p class="text-xs text-teal-700 font-medium mt-1">適合：{t.audience}</p>
              <p class="text-sm text-slate-600 mt-2 chinese-line-height line-clamp-3">{t.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-2xl bg-surface-container p-6 md:p-8">
      <h2 class="text-lg font-bold text-blue-950 mb-3 font-headline">關於這些計算機</h2>
      <ul class="text-sm text-slate-700 chinese-line-height list-disc pl-5 space-y-1">
        <li><strong>公式來源</strong>：BMI 分級採衛福部國健署成人標準；BMR 採 Mifflin-St Jeor（1990）；體脂率採 Deurenberg（1991）；GLP-1 適應症採國際肥胖學會與 FDA 標示常用門檻。</li>
        <li><strong>隱私</strong>：所有輸入儲存在您的瀏覽器（localStorage），不會上傳。可隨時清除。</li>
        <li><strong>限制</strong>：本站計算機僅供健康評估參考，不能取代醫師診斷與治療建議。</li>
      </ul>
    </section>
  </main>
</Layout>
