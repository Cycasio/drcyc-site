---
import Layout from '../../layouts/Layout.astro';
import MetricsForm from '../../components/tools/MetricsForm.astro';
import BmiWidget from '../../components/tools/BmiWidget.astro';
import IdealWeightWidget from '../../components/tools/IdealWeightWidget.astro';
import BmrWidget from '../../components/tools/BmrWidget.astro';
import TdeeWidget from '../../components/tools/TdeeWidget.astro';
import BodyFatWidget from '../../components/tools/BodyFatWidget.astro';
import WaistRatioWidget from '../../components/tools/WaistRatioWidget.astro';
import Glp1Widget from '../../components/tools/Glp1Widget.astro';
import WeightProgressWidget from '../../components/tools/WeightProgressWidget.astro';
import { TOOLS_SITE, BOOKING_URL } from '../../data/tools';

const title = '減重綜合儀表板｜BMI / TDEE / 體脂 / GLP-1 一頁全算｜陳昱彰醫師';
const description = '減重門診常用 8 大計算機一頁全算：BMI、理想體重、TDEE、體脂率、腰圍指標、GLP-1 適應症、減重進度。義大醫院家醫科陳昱彰醫師整理，可直接列印給患者帶走。';

const dashboardSchema = {
  '@type': 'MedicalWebPage',
  '@id': `${TOOLS_SITE}/tools/dashboard/#webpage`,
  url: `${TOOLS_SITE}/tools/dashboard/`,
  name: '減重綜合儀表板',
  description,
  inLanguage: 'zh-Hant',
  about: { '@type': 'MedicalEntity', name: '減重 / 肥胖醫學評估' },
  author: { '@id': `${TOOLS_SITE}/#person` },
};

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${TOOLS_SITE}/` },
    { '@type': 'ListItem', position: 2, name: '醫療計算機', item: `${TOOLS_SITE}/tools/` },
    { '@type': 'ListItem', position: 3, name: '減重綜合儀表板', item: `${TOOLS_SITE}/tools/dashboard/` },
  ],
};
---

<Layout title={title} description={description} jsonLd={[dashboardSchema, breadcrumb]}>
  <main class="max-w-5xl mx-auto px-6 md:px-10 py-12 print:py-4 print:px-4 print:max-w-none">
    <nav class="text-xs text-slate-500 mb-6 print:hidden" aria-label="breadcrumb">
      <a href="/" class="hover:text-teal-700">首頁</a>
      <span class="mx-2">／</span>
      <a href="/tools/" class="hover:text-teal-700">醫療計算機</a>
      <span class="mx-2">／</span>
      <span>減重綜合儀表板</span>
    </nav>

    <header class="mb-8 print:mb-3">
      <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-3">
        Weight Management Dashboard · 陳昱彰醫師
      </p>
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <h1 class="text-3xl md:text-4xl font-bold text-blue-950 font-headline">
          🩺 減重綜合儀表板
        </h1>
        <button
          type="button"
          id="print-btn"
          class="print:hidden bg-primary text-on-primary px-5 py-2.5 rounded-full font-bold text-sm tracking-tight hover:opacity-90 transition-opacity"
        >
          🖨️ 列印
        </button>
      </div>
      <p class="text-slate-600 chinese-line-height mt-3 print:mt-1 print:text-sm">
        BMI、理想體重、BMR/TDEE、體脂率、腰圍指標、GLP-1 適應症、減重進度——一頁全算完。輸入後即時計算，可直接列印給患者帶走。
      </p>
    </header>

    <MetricsForm
      fields={['sex', 'age', 'heightCm', 'weightKg', 'waistCm', 'hipCm', 'activityLevel', 'comorbidities', 'weightHistory']}
      title="病患資料"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 print:grid-cols-2 print:gap-3">
      <BmiWidget heading="① BMI" />
      <IdealWeightWidget heading="② 理想體重" />
      <BmrWidget heading="③ BMR 基礎代謝" />
      <TdeeWidget heading="④ TDEE 與減重熱量" />
      <BodyFatWidget heading="⑤ 體脂率" />
      <WaistRatioWidget heading="⑥ 腰圍指標" />
      <div class="md:col-span-2"><Glp1Widget heading="⑦ GLP-1 減重藥物資格" /></div>
      <div class="md:col-span-2"><WeightProgressWidget heading="⑧ 減重進度" /></div>
    </div>

    <section class="mt-12 print:hidden">
      <div class="rounded-2xl bg-gradient-to-br from-primary to-primary-container text-on-primary p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-bold mb-2 font-headline">需要醫師親自評估？</h2>
        <p class="text-on-primary-container chinese-line-height mb-4">
          歡迎線上預約義大醫院家醫科陳昱彰醫師門診，討論個人化減重療程、藥物適應症、共病管理。
        </p>
        <a
          href={BOOKING_URL}
          target="_blank"
          rel="noopener"
          class="inline-block bg-white text-primary px-6 py-3 rounded-full font-bold text-sm tracking-tight hover:opacity-90 transition-opacity no-underline"
        >
          義大醫院線上預約掛號 →
        </a>
      </div>
    </section>

    <footer class="mt-12 text-xs text-slate-500 chinese-line-height border-t border-outline-variant pt-6 print:mt-4 print:pt-2 print:text-[10px]">
      <p class="font-bold mb-2 text-slate-700">⚠️ 醫療免責聲明</p>
      <p>
        本儀表板公式採用衛福部國民健康署及國際公認之臨床標準，僅供健康評估參考，<strong>不能取代醫師診斷或治療建議</strong>。
      </p>
      <p class="mt-2 print:hidden">
        本網站不儲存任何個人資料，所有輸入僅儲存在您的瀏覽器，可隨時於上方表單清除。
      </p>
      <p class="hidden print:block mt-2">
        本頁印製時間：<span id="print-timestamp"></span>
      </p>
    </footer>
  </main>
</Layout>

<script>
  const btn = document.getElementById('print-btn');
  btn?.addEventListener('click', () => {
    const ts = document.getElementById('print-timestamp');
    if (ts) ts.textContent = new Date().toLocaleString('zh-TW');
    window.print();
  });
</script>

<style is:global>
  @media print {
    /* 印刷時收縮的細節 */
    body { background: white !important; font-size: 12pt; }
    main { padding: 0 !important; }
    /* 兩欄列印更緊湊 */
    section[data-bmi-widget],
    section[data-ideal-weight-widget],
    section[data-bmr-widget],
    section[data-tdee-widget],
    section[data-body-fat-widget],
    section[data-waist-widget],
    section[data-glp1-widget],
    section[data-progress-widget] {
      box-shadow: none !important;
      border: 1px solid #cbd5e1 !important;
      page-break-inside: avoid;
    }
  }
</style>
