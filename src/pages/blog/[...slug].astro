---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();
const h2Headings = headings.filter(h => h.depth === 2);

// 自動找 3 篇相關文章:優先同 category + 重疊 tag 多者
function findRelated(currentSlug: string, currentCategory: string | undefined, currentTags: string[] | undefined, all: typeof allPosts) {
  const tags = currentTags ?? [];
  const scored = all
    .filter((p) => p.slug !== currentSlug)
    .map((p) => {
      let score = 0;
      if (currentCategory && p.data.category === currentCategory) score += 10;
      const overlap = (p.data.tags ?? []).filter((t) => tags.includes(t)).length;
      score += overlap * 3;
      return { post: p, score };
    })
    .filter((x) => x.score > 0)
    .sort((a, b) => b.score - a.score);
  return scored.slice(0, 3).map((x) => x.post);
}

const relatedPosts = findRelated(post.slug, post.data.category, post.data.tags, allPosts);

const dateStr = post.data.pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updatedStr = post.data.updatedDate
  ? post.data.updatedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
const firstTag = post.data.tags?.[0];

const SITE = 'https://www.drcyc.io';
const postUrl = `${SITE}/blog/${post.slug}/`;
const postImage = post.data.image && post.data.image.length > 0
  ? (post.data.image.startsWith('http') ? post.data.image : `${SITE}${post.data.image}`)
  : `${SITE}/images/portrait.jpg`;

const articleType = post.data.scholarly ? 'MedicalScholarlyArticle' : 'BlogPosting';
const blogPostingSchema = {
  '@type': articleType,
  '@id': `${postUrl}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  headline: post.data.title,
  description: post.data.description,
  image: postImage,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  inLanguage: 'zh-Hant',
  author: { '@id': `${SITE}/#person` },
  publisher: { '@id': `${SITE}/#person` },
  keywords: post.data.tags?.join(', '),
  articleSection: post.data.category,
  url: postUrl,
  ...(post.data.medicalCondition
    ? { about: { '@type': 'MedicalCondition', name: post.data.medicalCondition } }
    : {}),
  ...(post.data.scholarly
    ? {
        specialty: 'FamilyPractice',
        reviewedBy: { '@id': `${SITE}/#person` },
      }
    : {}),
  // Speakable: 朗讀標題與 FAQ 答案（Google Assistant / Siri 等語音助手）
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['article h1', 'article h2', '[data-speakable="true"]'],
  },
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: '衛教專欄', item: `${SITE}/blog/` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
  ],
};

const faqSchema = post.data.faq && post.data.faq.length > 0
  ? {
      '@type': 'FAQPage',
      '@id': `${postUrl}#faq`,
      mainEntity: post.data.faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

const postJsonLd = [blogPostingSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<Layout
  title={`${post.data.title}｜陳昱彰醫師`}
  description={post.data.description}
  ogImage={postImage}
  ogType="article"
  jsonLd={postJsonLd}
>
  <main class="max-w-7xl mx-auto px-6 md:px-12 py-16">
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_16rem] lg:gap-16">
      <!-- Article Canvas -->
      <article class="max-w-[720px] mx-auto lg:mx-0 min-w-0">
        <!-- Category Label + Date + Last Updated -->
        <div class="flex items-center gap-3 mb-6 flex-wrap">
          {firstTag && (
            <span class="text-xs font-bold tracking-widest text-on-surface-variant uppercase bg-surface-container-low px-3 py-1 rounded-full">
              {firstTag}
            </span>
          )}
          <span class="text-xs text-outline">發布 {dateStr}</span>
          {updatedStr && updatedStr !== dateStr && (
            <span class="text-xs text-teal-700 font-medium">· 最後更新 {updatedStr}</span>
          )}
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-primary mb-8 leading-tight font-headline">
          {post.data.title}
        </h1>

        <!-- TL;DR callout(AI 摘要引擎與行動讀者的「30 秒答案」) -->
        {post.data.tldr && post.data.tldr.length > 0 && (
          <aside
            class="mb-10 rounded-2xl border-l-4 border-teal-500 bg-teal-50/60 p-5 md:p-6"
            aria-label="重點摘要"
            data-speakable="true"
          >
            <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-3">⚡ 重點 {post.data.tldr.length} 句話</p>
            <ul class="space-y-2 chinese-line-height">
              {post.data.tldr.map((point) => (
                <li class="flex gap-2 text-slate-800">
                  <span class="text-teal-600 mt-1 shrink-0">●</span>
                  <span set:html={point}></span>
                </li>
              ))}
            </ul>
          </aside>
        )}

        <!-- Featured Image -->
        {post.data.image && (
          <div class="mb-12 rounded-xl overflow-hidden bg-surface-container-low">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full aspect-[16/9] object-cover"
              loading="eager"
            />
          </div>
        )}

        <!-- Article Content -->
        <div class="article-content">
          <Content />
        </div>

        <!-- 可見 FAQ(同一份 frontmatter 同時餵 FAQPage schema 與頁面可見內容,符合 Google 規範 + AI 可截取) -->
        {post.data.faq && post.data.faq.length > 0 && (
          <section class="mt-16 pt-10 border-t border-slate-200" aria-label="常見問題" id="faq">
            <h2 class="text-2xl font-bold text-blue-950 font-headline mb-6">常見問題</h2>
            <div class="space-y-3">
              {post.data.faq.map((item) => (
                <details class="group rounded-2xl border border-slate-200 bg-white p-5 open:bg-teal-50/30 open:border-teal-200">
                  <summary class="flex items-start gap-3 cursor-pointer list-none font-bold text-blue-950 chinese-line-height">
                    <span class="text-teal-600 shrink-0 mt-0.5 transition-transform group-open:rotate-45">＋</span>
                    <span set:html={item.q}></span>
                  </summary>
                  <div class="mt-3 pl-7 text-slate-700 chinese-line-height" set:html={item.a}></div>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- 醫療免責聲明(每篇文末顯性呈現,因 AI 摘要常只截正文不含 Footer) -->
        <aside class="mt-12 rounded-xl border-l-4 border-slate-300 bg-slate-50 p-5 text-sm text-slate-600 chinese-line-height" aria-label="醫療免責聲明">
          <p><strong class="text-slate-700">醫療免責聲明</strong>：本文由義大醫院家庭暨社區醫學部 <a href="/about/" rel="author" class="text-teal-700 underline">陳昱彰醫師</a> 整理，基於發表時的實證醫學文獻，僅供衛教參考，<strong>不能取代醫師對個別狀況的診斷與治療建議</strong>。實際用藥、檢查與治療請與您的主治醫師討論，並以醫療院所最新公告為準。</p>
        </aside>

        <!-- 自動延伸閱讀(主題網絡 + 內鏈密度) -->
        {relatedPosts.length > 0 && (
          <section class="mt-16 pt-10 border-t border-slate-200" aria-label="延伸閱讀">
            <h2 class="text-2xl font-bold text-blue-950 font-headline mb-6">延伸閱讀</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {relatedPosts.map((r) => (
                <a
                  href={`/blog/${r.slug}/`}
                  class="block p-5 rounded-2xl bg-white border border-slate-200 hover:border-primary hover:shadow-md transition-all no-underline"
                >
                  {r.data.category && (
                    <span class="text-xs font-bold tracking-widest text-teal-700 uppercase">{r.data.category}</span>
                  )}
                  <h3 class="text-base font-bold text-blue-950 mt-2 font-headline line-clamp-2">{r.data.title}</h3>
                  <p class="text-sm text-slate-600 mt-2 line-clamp-3 chinese-line-height">{r.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Bottom CTA Card -->
        <section class="mt-20 p-10 bg-gradient-to-br from-primary to-primary-container rounded-2xl text-on-primary text-center">
          <h3 class="text-2xl md:text-3xl font-bold mb-4 font-headline">預約您的健康諮詢</h3>
          <p class="text-on-primary-container mb-8 max-w-md mx-auto">
            想進一步了解如何優化個人健康？歡迎預約門診時段，我們將為您制定專屬的衛教計畫。
          </p>
          <a
            href="https://webreg.edah.org.tw/Register/ChooseDoctorTime/2675"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 bg-secondary-container text-on-secondary-fixed-variant px-8 py-3 rounded-full font-bold text-lg hover:opacity-90 transition-all no-underline"
          >
            →
            立即線上掛號
          </a>
        </section>
      </article>

      <!-- Sticky Sidebar (TOC) -->
      <aside class="hidden lg:block w-64">
        <div class="sticky top-28 space-y-8">
          {h2Headings.length > 0 && (
            <div>
              <h4 class="text-xs font-bold tracking-[0.1em] text-outline uppercase mb-4">目錄索引</h4>
              <nav class="flex flex-col space-y-4" id="toc-nav">
                {h2Headings.map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    class="text-slate-500 hover:text-primary transition-colors pl-3 text-sm toc-link no-underline"
                    data-heading={heading.slug}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <!-- Author Bio Card -->
          <a href="/about/" rel="author" class="block p-6 bg-surface-container-low rounded-xl no-underline hover:bg-surface-container transition-colors">
            <div class="flex items-center gap-4 mb-4">
              <img
                src="/images/portrait.jpg"
                alt="陳昱彰醫師 Dr. Yu-Chang Chen"
                class="w-12 h-12 rounded-full object-cover shrink-0"
                width="48"
                height="48"
                loading="lazy"
              />
              <div>
                <p class="text-sm font-bold text-primary">陳昱彰醫師 YC Chen, MD</p>
                <p class="text-xs text-outline">家醫 / 肥胖 / 骨鬆 三專科</p>
              </div>
            </div>
            <p class="text-xs text-on-surface-variant leading-relaxed chinese-line-height">
              義大醫院家庭暨社區醫學部主治醫師，結合行為科學與實證醫學。國家醫療品質獎實證銀獎、ACE-CPT 認證教練。
            </p>
            <p class="text-xs font-bold text-teal-700 mt-3">了解更多 →</p>
          </a>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<style is:global>
  .article-content p {
    line-height: 1.8;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    color: #43474e;
  }
  .article-content h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #022448;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }
  .article-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #022448;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }
  .article-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #022448;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .article-content blockquote {
    border-left: 8px solid #006a60;
    background: #ffffff;
    padding: 2rem;
    border-radius: 0 0.75rem 0.75rem 0;
    margin: 2rem 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #022448;
    line-height: 1.6;
  }
  .article-content a {
    color: #006a60;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .article-content a:hover {
    color: #022448;
  }
  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: #43474e;
  }
  .article-content li {
    margin-bottom: 0.5rem;
    line-height: 1.8;
  }
  .article-content strong {
    color: #191c1d;
    font-weight: 600;
  }
  .article-content hr {
    border: none;
    border-top: 1px solid #c4c6cf;
    margin: 2.5rem 0;
  }
  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .article-content th,
  .article-content td {
    padding: 0.75rem 1rem;
    border: 1px solid #c4c6cf;
    text-align: left;
  }
  .article-content th {
    background-color: #f3f4f5;
    font-weight: 600;
    color: #191c1d;
  }
  .article-content td {
    color: #43474e;
  }
  .toc-link.active {
    color: #006a60;
    font-weight: 700;
  }
</style>

<script>
  const tocLinks = document.querySelectorAll('.toc-link');
  if (tocLinks.length > 0) {
    const headingEls = Array.from(tocLinks).map(link => {
      const slug = link.getAttribute('data-heading');
      return slug ? document.getElementById(slug) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-link[data-heading="${entry.target.id}"]`);
            activeLink?.classList.add('active');
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px' }
    );

    headingEls.forEach(el => observer.observe(el));
  }
</script>
