---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | 陳昱彰醫師`} description={post.data.description}>
  <article class="container mx-auto px-4 py-12 max-w-3xl">
    <header class="mb-8">
      <a href="/blog" class="text-blue-600 hover:underline text-sm mb-4 inline-block">← 返回衛教專欄</a>
      <h1 class="text-3xl font-bold mt-2">{post.data.title}</h1>
      <div class="flex items-center gap-4 mt-4 text-gray-600">
        <span>{post.data.author}</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      {post.data.tags && (
        <div class="flex gap-2 mt-3">
          {post.data.tags.map((tag) => (
            <span class="bg-blue-50 text-blue-700 px-2 py-0.5 rounded text-sm">{tag}</span>
          ))}
        </div>
      )}
    </header>
    
    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-a:text-blue-600 prose-table:text-sm">
      <Content />
    </div>
    
    <footer class="mt-12 pt-8 border-t">
      <div class="bg-blue-50 rounded-lg p-6">
        <h3 class="font-bold text-lg mb-2">預約門診</h3>
        <p class="text-gray-700 mb-4">如果這篇文章對你有幫助，歡迎來門診進一步諮詢。</p>
        <a 
          href="https://webreg.edah.org.tw/Register/ChooseDoctorTime/2675" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors"
        >
          線上掛號
        </a>
      </div>
    </footer>
  </article>
</Layout>

<style>
  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .prose table {
    width: 100%;
  }
  .prose th, .prose td {
    padding: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  .prose th {
    background-color: #f9fafb;
  }
</style>
