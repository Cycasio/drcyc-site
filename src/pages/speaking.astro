---
import Layout from '../layouts/Layout.astro';
import { CLIENTS, TOPICS, FORMATS, FAQ, CONTACT } from '../data/speaking';

const SITE = 'https://www.drcyc.io';
const pageUrl = `${SITE}/speaking/`;

const serviceSchema = {
  '@type': 'Service',
  '@id': `${pageUrl}#service`,
  name: '企業衛教講座 / 健康演講',
  serviceType: 'HealthEducationLecture',
  url: pageUrl,
  provider: { '@id': `${SITE}/#person` },
  areaServed: CONTACT.areaServed.map((a) => ({ '@type': 'Place', name: a })),
  audience: [
    { '@type': 'Audience', audienceType: '企業 HR / 健康管理師' },
    { '@type': 'Audience', audienceType: '廠護 / 職安衛委員會' },
    { '@type': 'Audience', audienceType: '學校與公所' },
    { '@type': 'Audience', audienceType: '社區鄉鎮衛生所' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: '演講主題',
    itemListElement: TOPICS.map((t) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: t.title,
        description: t.description,
      },
    })),
  },
};

const faqSchema = {
  '@type': 'FAQPage',
  '@id': `${pageUrl}#faq`,
  mainEntity: FAQ.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: '衛教演講 / 企業健康講座', item: pageUrl },
  ],
};

const totalClients = CLIENTS.reduce((n, g) => n + g.clients.length, 0);

const title = '企業衛教講座 / 健康演講|家醫科陳昱彰醫師・南部演講邀約';
const description =
  '家醫科陳昱彰醫師提供企業健康講座與衛教演講服務,主題涵蓋減重醫學、GLP-1 新藥、三高慢性病、骨質疏鬆、行為科學、職場健康與四大計畫。曾服務中鋼、中油、國巨、李長榮、英特格、麥當勞、高雄銀行、Anytime Fitness、東海/義大/高科大/中正大學、各地警政機關與衛生所。南部為主、線上場次可接。邀約請來信 cyc@edfm.org。';
---

<Layout title={title} description={description} jsonLd={[serviceSchema, faqSchema, breadcrumbSchema]}>
  <main class="max-w-5xl mx-auto px-6 md:px-10 py-12">
    <!-- Breadcrumb -->
    <nav class="text-xs text-slate-500 mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-teal-700">首頁</a>
      <span class="mx-2">／</span>
      <span>衛教演講 / 企業健康講座</span>
    </nav>

    <!-- Hero -->
    <header class="mb-12">
      <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-3">Health Education Speaking · Keynote</p>
      <h1 class="text-3xl md:text-5xl font-extrabold text-blue-950 leading-tight mb-5">
        衛教演講 ·<br />企業健康講座
      </h1>
      <p class="text-lg text-slate-700 leading-relaxed max-w-3xl chinese-line-height">
        我是義大醫院家醫科主治醫師<strong>陳昱彰</strong>,國家醫療品質獎實證醫學類臨床組銀獎、
        <strong>家醫 / 肥胖 / 骨鬆三專科醫師</strong>,過去在<strong
          >大學、上市櫃企業、政府機關、中小學、社區衛生所</strong
        >都有過不少演講經驗。主題從減重新藥、三高慢性病、骨鬆肌少,到職場健康與行為改變都有。
      </p>
      <p class="text-base text-slate-600 mt-4 leading-relaxed chinese-line-height max-w-3xl">
        我的演講風格不是「背投影片」,而是用<strong>實證數據 + 員工真實案例 + 行為科學工具</strong
        >,讓聽眾帶得走具體可以執行的東西。如果你正在尋找一場能讓員工「真的改變」的健康講座,歡迎來信邀約。
      </p>
    </header>

    <!-- Quick facts -->
    <section class="grid sm:grid-cols-3 gap-4 mb-14">
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
        <div class="text-3xl font-extrabold text-teal-700">{totalClients}+</div>
        <p class="text-xs text-slate-600 mt-1">合作單位(部份可公開)</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
        <div class="text-3xl font-extrabold text-teal-700">6</div>
        <p class="text-xs text-slate-600 mt-1">核心講題</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
        <div class="text-3xl font-extrabold text-teal-700">南部 + 線上</div>
        <p class="text-xs text-slate-600 mt-1">服務範圍</p>
      </div>
    </section>

    <!-- Topics -->
    <section id="topics" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-2">六大核心講題</h2>
      <p class="text-sm text-slate-600 mb-6">以下是目前最受企業與機構歡迎的主題。實際演講內容會依貴單位的需求與聽眾背景客製調整。</p>
      <div class="grid md:grid-cols-2 gap-5">
        {TOPICS.map((t) => (
          <article class="rounded-xl border border-slate-200 bg-white p-6 hover:border-teal-600/40 transition-colors">
            <div class="flex items-start gap-4 mb-3">
              <div class="w-12 h-12 rounded-xl bg-teal-50 text-teal-700 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined" style="font-size:26px;">{t.icon}</span>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-blue-950 text-lg leading-tight">{t.title}</h3>
                <p class="text-xs text-teal-700 font-semibold mt-1">{t.subtitle}</p>
              </div>
            </div>
            <p class="text-sm text-slate-700 leading-relaxed chinese-line-height mb-3">{t.description}</p>
            <div class="flex flex-wrap gap-2">
              {t.keywords.map((k) => (
                <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">#{k}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Formats -->
    <section id="formats" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-6">三種演講形式</h2>
      <div class="grid md:grid-cols-3 gap-4">
        {FORMATS.map((f) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <p class="text-xs font-bold tracking-widest text-teal-700 uppercase mb-2">{f.duration}</p>
            <h3 class="text-lg font-bold text-blue-950 mb-2">{f.name}</h3>
            <p class="text-xs text-slate-500 mb-4 leading-relaxed chinese-line-height">適合:{f.bestFor}</p>
            <ul class="text-sm text-slate-700 space-y-1 chinese-line-height">
              {f.includes.map((i) => (
                <li class="flex items-start gap-2">
                  <span class="text-teal-700 mt-0.5">✓</span>
                  <span>{i}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Past Clients -->
    <section id="clients" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-2">過去合作單位</h2>
      <p class="text-sm text-slate-600 mb-6">以下列出部分可公開的合作單位。實際演講場次多於清單(包括多場巡迴的衛生所、國中小、警政單位未全數列出)。</p>
      <div class="space-y-5">
        {CLIENTS.map((g) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-teal-700" style="font-size:24px;">{g.icon}</span>
              <h3 class="font-bold text-blue-950">{g.category}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {g.clients.map((c) => (
                <span class="inline-block px-3 py-1.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full text-sm">
                  {c}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="mb-14">
      <h2 class="text-2xl font-bold text-blue-950 mb-6">邀約常見問題</h2>
      <div class="space-y-3">
        {FAQ.map((f) => (
          <details class="group rounded-xl border border-slate-200 bg-white">
            <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-blue-950 flex justify-between items-center">
              <span>{f.q}</span>
              <span class="text-teal-700 text-xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-slate-700 leading-relaxed chinese-line-height">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="rounded-2xl bg-gradient-to-br from-blue-950 to-teal-700 text-white p-10 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">想邀請陳醫師到貴單位演講?</h2>
      <p class="text-white/80 mb-6 max-w-2xl mx-auto leading-relaxed chinese-line-height">
        請來信告訴我:<strong>貴單位名稱 / 預定時段 / 主題方向 / 聽眾人數 / 地點或線上</strong>。我會在 1–2 個工作天內回覆可行時段與報價。
      </p>
      <div class="flex flex-wrap gap-3 justify-center text-sm">
        <a
          href={`mailto:${CONTACT.email}?subject=%E6%BC%94%E8%AC%9B%E9%82%80%E7%B4%84%20-%20%E9%99%B3%E6%98%B1%E5%BD%B0%E9%86%AB%E5%B8%AB`}
          class="inline-flex items-center gap-2 bg-white text-blue-950 px-6 py-3 rounded-full font-bold hover:opacity-90 no-underline"
        >
          <span class="material-symbols-outlined" style="font-size:20px;">mail</span>
          {CONTACT.email}
        </a>
        <a
          href={CONTACT.facebook}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-white/10 border border-white/40 text-white px-6 py-3 rounded-full font-bold hover:bg-white/20 no-underline"
        >
          Facebook @lazydr
        </a>
      </div>
      <p class="text-xs text-white/60 mt-6">服務範圍:{CONTACT.areaServed.join('・')}</p>
    </section>
  </main>
</Layout>
