---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = '陳昱彰醫師 Dr. Yu-Chang Chen｜義大醫院家醫科・減重門診',
  description = '義大醫院家醫科主治醫師陳昱彰，三專科醫師（家醫、肥胖、骨鬆），結合 COM-B 行為科學與實證醫學，提供高雄減重門診、骨質疏鬆、企業臨場與職業醫學服務。國家醫療品質獎實證銀獎。',
  ogImage = '/images/portrait.jpg',
  ogType = 'website',
  jsonLd,
} = Astro.props as Props;

const SITE = 'https://www.drcyc.io';
const canonical = new URL(Astro.url.pathname, SITE).toString();
const ogImageAbs = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE}/#person`,
  name: '陳昱彰',
  alternateName: ['Yu-Chang Chen', 'Chen Yu-Chang'],
  honorificSuffix: 'MD',
  jobTitle: '家庭醫學科主治醫師',
  image: `${SITE}/images/portrait.jpg`,
  url: SITE,
  email: 'mailto:cyc@edfm.org',
  gender: 'Male',
  nationality: 'Taiwanese',
  description:
    '義大醫院家庭暨社區醫學部主治醫師與減重中心醫師，整合家庭醫學、肥胖醫學、運動醫學與職業醫學，以行為科學為核心協助民眾進行減重治療與慢性病管理。國家醫療品質獎實證醫學臨床組銀獎。',
  knowsAbout: [
    '家庭醫學',
    '肥胖醫學',
    '減重治療',
    '運動醫學',
    '職業醫學',
    '骨質疏鬆',
    '行為科學',
    '實證醫學',
    'COM-B 行為改變模型',
    '動機式晤談',
    'GLP-1 藥物',
    'Tirzepatide',
  ],
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: '高雄醫學大學', url: 'https://www.kmu.edu.tw' },
    { '@type': 'CollegeOrUniversity', name: '國立臺灣大學公共衛生學院' },
  ],
  worksFor: {
    '@type': 'Hospital',
    name: '義大醫院',
    url: 'https://www.edah.org.tw',
  },
  affiliation: {
    '@type': 'Hospital',
    name: '義大醫院家庭暨社區醫學部',
    url: 'https://www.edah.org.tw',
  },
  memberOf: [
    { '@type': 'Organization', name: '台灣家庭醫學醫學會' },
    { '@type': 'Organization', name: '台灣肥胖醫學會' },
    { '@type': 'Organization', name: '中華民國骨質疏鬆症學會' },
  ],
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', credentialCategory: '專科證照', name: '家庭醫學科專科醫師' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: '專科證照', name: '肥胖醫學專科醫師' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: '專科證照', name: '骨質疏鬆症專科醫師' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: '認證', name: '勞工健康服務醫師' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: '認證', name: '戒菸治療認證醫師' },
  ],
  award: [
    '國家醫療品質獎 實證醫學類 臨床組 銀獎',
    '國家醫療品質獎 實證醫學類 新人組 佳作',
    '醫策會 EBM 競賽 臨床組 佳作',
  ],
  identifier: [
    { '@type': 'PropertyValue', propertyID: 'ORCID', value: '0009-0005-2506-1058' },
  ],
  sameAs: [
    'https://www.facebook.com/lazydr',
    'https://www.instagram.com/lazydr.cyc',
    'https://orcid.org/0009-0005-2506-1058',
  ],
};

const physicianSchema = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  '@id': `${SITE}/#physician`,
  name: '陳昱彰醫師門診 - 義大醫院',
  url: SITE,
  image: `${SITE}/images/portrait.jpg`,
  telephone: '+886-7-615-0011',
  priceRange: '$$',
  medicalSpecialty: ['FamilyMedicine', 'Obesity', 'OccupationalMedicine', 'SportsMedicine'],
  availableService: [
    { '@type': 'MedicalProcedure', name: '減重管理門診', description: '結合 COM-B 行為科學、營養、運動處方與藥物治療（Contrave、Mounjaro 等 GLP-1）的個人化減重療程' },
    { '@type': 'MedicalProcedure', name: '骨質疏鬆門診', description: '骨密度評估、FRAX 風險預估、藥物與生活型態治療' },
    { '@type': 'MedicalProcedure', name: '企業臨場健康服務', description: '依《職業安全衛生法》提供勞工健康保護四大計畫' },
    { '@type': 'MedicalProcedure', name: '高階健康檢查解讀', description: '結合行為科學的個人化健檢諮詢' },
    { '@type': 'MedicalProcedure', name: '運動處方諮詢', description: '個人化運動處方設計與運動傷害評估' },
  ],
  parentOrganization: {
    '@type': 'Hospital',
    name: '義大醫院',
    url: 'https://www.edah.org.tw',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '燕巢區角宿里義大路 1 號',
    addressLocality: '高雄市',
    addressRegion: '高雄市',
    postalCode: '82445',
    addressCountry: 'TW',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 22.7345,
    longitude: 120.3882,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Monday', opens: '08:30', closes: '12:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Tuesday', opens: '08:30', closes: '12:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '08:30', closes: '12:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '13:30', closes: '17:00' },
  ],
  potentialAction: {
    '@type': 'ReserveAction',
    target: 'https://webreg.edah.org.tw/Register/ChooseDoctorTime/2675',
    name: '線上預約掛號',
  },
};

const qishanClinicSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  '@id': `${SITE}/#qishan-clinic`,
  name: '大政診所(陳昱彰醫師 週五夜診)',
  url: `${SITE}/qishan-clinic/`,
  telephone: '+886-7-662-2588',
  hasMap: 'https://maps.app.goo.gl/JcgmsZQqFahbT2T1A',
  medicalSpecialty: ['FamilyMedicine', 'Obesity'],
  physician: { '@id': `${SITE}/#person` },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '旗山區',
    addressLocality: '旗山區',
    addressRegion: '高雄市',
    postalCode: '842',
    addressCountry: 'TW',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 22.892365,
    longitude: 120.4836464,
  },
  areaServed: [
    { '@type': 'City', name: '高雄市旗山區' },
    { '@type': 'City', name: '高雄市美濃區' },
    { '@type': 'City', name: '高雄市田寮區' },
    { '@type': 'City', name: '高雄市內門區' },
  ],
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '18:00', closes: '21:00' },
  ],
  availableService: [
    { '@type': 'MedicalProcedure', name: '家庭醫學科夜診' },
    { '@type': 'MedicalProcedure', name: '三高慢性病追蹤(糖尿病、高血壓、高血脂)' },
    { '@type': 'MedicalProcedure', name: '藥物減重諮詢(含 GLP-1 類)' },
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  url: SITE,
  name: '陳昱彰醫師 Dr. Yu-Chang Chen',
  inLanguage: 'zh-Hant',
  publisher: { '@id': `${SITE}/#person` },
};

const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    personSchema,
    physicianSchema,
    qishanClinicSchema,
    websiteSchema,
    ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
  ],
};
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="陳昱彰醫師 Dr. Yu-Chang Chen" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <link rel="canonical" href={canonical} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Public+Sans:wght@300;400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="陳昱彰醫師 Dr. Yu-Chang Chen" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content={ogImageAbs} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbs} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
</head>
<body class="bg-surface text-on-surface font-body antialiased">
  <Nav />
  <slot />
  <Footer />
</body>
</html>

<style is:global>
  h1, h2, h3, h4 { font-family: 'Manrope', sans-serif; }
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 40;
    line-height: 1;
  }
  .material-symbols-outlined.filled {
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 40;
  }
  .chinese-line-height { line-height: 1.8; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  html { scroll-behavior: smooth; }
</style>
