---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { title = '陳昱彰醫師 Dr. Yu-Chang Chen', description = '家庭醫學科醫師｜行為科學 × 臨床醫學' } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href="https://drcyc.io" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Public+Sans:wght@300;400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://drcyc.io" />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content="https://drcyc.io/images/portrait.jpg" />
  <meta name="twitter:image" content="https://drcyc.io/images/portrait.jpg" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- JSON-LD: Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "陳昱彰",
    "alternateName": "Yu-Chang Chen",
    "jobTitle": "家庭醫學科主治醫師",
    "worksFor": {
      "@type": "Hospital",
      "name": "義大醫院",
      "url": "https://www.edah.org.tw"
    },
    "url": "https://drcyc.io",
    "sameAs": [
      "https://www.facebook.com/lazydr"
    ],
    "knowsAbout": ["家庭醫學","肥胖醫學","運動醫學","職業醫學","骨質疏鬆","行為科學","實證醫學"],
    "description": "義大醫院家庭暨社區醫學部主治醫師與減重中心醫師，專注整合家庭醫學、肥胖醫學、運動醫學與職業醫學，以行為科學為核心協助民眾進行減重治療與慢性病管理。",
    "alumniOf": {"@type":"CollegeOrUniversity","name":"高雄醫學大學"}
  })} />

  <!-- JSON-LD: MedicalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalBusiness",
    "name": "陳昱彰醫師門診",
    "url": "https://drcyc.io",
    "medicalSpecialty": ["FamilyMedicine"],
    "parentOrganization": {
      "@type": "Hospital",
      "name": "義大醫院"
    }
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "陳醫師的門診在哪裡？",
        "acceptedAnswer": { "@type": "Answer", "text": "義大醫院家庭醫學科及義大減重中心。" }
      },
      {
        "@type": "Question",
        "name": "陳醫師的專長有哪些？",
        "acceptedAnswer": { "@type": "Answer", "text": "家庭醫學、肥胖醫學、運動醫學、職業醫學、骨質疏鬆、行為科學、實證醫學。" }
      },
      {
        "@type": "Question",
        "name": "什麼是行為科學導向的醫療？",
        "acceptedAnswer": { "@type": "Answer", "text": "結合 COM-B 模型、動機式晤談等行為改變技術，幫助病患建立可持續的健康習慣，而非只開藥治療。" }
      },
      {
        "@type": "Question",
        "name": "減重門診的方式？",
        "acceptedAnswer": { "@type": "Answer", "text": "採用實證醫學方法，結合營養、行為科學與運動處方，制定個人化減重策略。" }
      }
    ]
  })} />
</head>
<body class="bg-surface text-on-surface font-body antialiased">
  <Nav />
  <slot />
  <Footer />
</body>
</html>

<style is:global>
  h1, h2, h3, h4 { font-family: 'Manrope', sans-serif; }
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .chinese-line-height { line-height: 1.8; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  html { scroll-behavior: smooth; }
</style>
