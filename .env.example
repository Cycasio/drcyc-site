# drcyc-site 環境變數模板
# 複製為 .env.local 並填入實際 token / ID

# Cloudflare Web Analytics(免費,隱私友善,無需 cookie banner)
# 取得:Cloudflare Dashboard → Analytics & Logs → Web Analytics → Add a site → drcyc-site
# → 拿到 data-cf-beacon 內 token 值貼下方
# 範例:PUBLIC_CF_BEACON_TOKEN=abc123def456...
PUBLIC_CF_BEACON_TOKEN=

# Microsoft Clarity(免費 heatmap + session 錄影)
# 取得:https://clarity.microsoft.com/ → Create new project → 拿 project ID
# 範例:PUBLIC_CLARITY_ID=abcd1234ef
PUBLIC_CLARITY_ID=

# Cloudflare deploy(可放 Mac mini / iMac shell rc)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=6378a267a85bb0f9d0e7b6a1fe95072b
